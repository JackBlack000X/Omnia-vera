{
  "expo": {
    "name": "Tothemoon",
    "slug": "habit-check-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "habitchecknative",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jackblack000x.habitchecknative",
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tothemoon usa la tua posizione per mostrarti funzioni extra legate ai luoghi (es. completare automaticamente la task \"Palestra\" quando esci dalla palestra).",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Tothemoon ha bisogno dell’accesso alla posizione anche in background per completare automaticamente alcune task quando entri o esci da luoghi salvati, anche con l’app chiusa."
      },
      "entitlements": {}
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jackblack000x.habitchecknative",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "Tothemoon vuole accedere al calendario per importare i tuoi eventi e mostrarli nell'app."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tothemoon usa la tua posizione per attivare funzioni extra come il completamento automatico di alcune task quando esci da luoghi salvati, anche con l’app in background.",
          "locationWhenInUsePermission": "Tothemoon usa la tua posizione per mostrarti funzioni extra legate ai luoghi mentre utilizzi l’app."
        }
      ],
      [
        "rn-group-preferences",
        {
          "appGroup": "group.com.jackblack000x.habitchecknative"
        }
      ],
      [
        "react-native-widget-extension",
        {
          "widgetsFolder": "widgets/TothemoonWidgets",
          "groupIdentifier": "group.com.jackblack000x.habitchecknative"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "./plugins/with-tothemoon-action-button",
      "./plugins/with-tothemoon-widget-center",
      "./plugins/with-ios-26-fmt-fix",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
